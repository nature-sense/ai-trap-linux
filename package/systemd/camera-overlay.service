[Unit]
Description=Load IMX708 camera overlay at runtime
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStartPre=/bin/sleep 10
ExecStartPre=/bin/sh -c 'for f in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do echo powersave > $f; done'
ExecStart=/usr/bin/dtoverlay imx708
ExecStartPost=/bin/sh -c 'for f in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do echo ondemand > $f; done'

[Install]
WantedBy=multi-user.target
