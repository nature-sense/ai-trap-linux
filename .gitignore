# Build directories
build/
build-*/

# Cross-compilation sysroot (built by scripts/build-luckfox-deps.sh)
sysroot/

# Model weights — .param and .bin are small enough to commit.
# .rknn files are larger compiled outputs — regenerate from .onnx.
models/*.rknn
models/*.onnx

# Runtime outputs
crops/
*.db
*.db-wal
*.db-shm

# Package build artifacts (binary, bundled libs, models — generated not source)
package/bin/
package/lib/
package/models/
package/share/
