# Build directories
build/
build-*/

# Cross-compilation sysroot (built by scripts/build-luckfox-deps.sh)
sysroot/

# Model weights — source (.pt) and all converted outputs (.param/.bin/.onnx/.rknn) are committed.
# Ultralytics ncnn export writes a temp directory next to the .pt — ignore it.
*_ncnn_model/

# Runtime outputs
crops/
*.db
*.db-wal
*.db-shm

# Package build artifacts (binary, bundled libs, models — generated not source)
package/bin/
package/lib/
package/models/
package/share/

# Luckfox OS firmware images (large binaries — download via scripts/luckfox-firmware-fetch.sh)
luckfox/system/

# ESP32-P4 / ESP-IDF generated files
firmware-esp32p4/build/
firmware-esp32p4/managed_components/
firmware-esp32p4/sdkconfig
firmware-esp32p4/.cache/
