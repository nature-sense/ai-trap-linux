# Build directories
build/
build-*/

# Cross-compilation sysroot (built by scripts/build-luckfox-deps.sh)
sysroot/

# Model weights — source (.pt) and all converted outputs (.param/.bin/.onnx/.rknn) are committed.
# Ultralytics ncnn export writes a temp directory next to the .pt — ignore it.
*_ncnn_model/

# Runtime outputs
crops/
*.db
*.db-wal
*.db-shm

# Package build artifacts (binary, bundled libs, models — generated not source)
package/bin/
package/lib/
package/models/
package/share/
